<!DOCTYPE html>
<html lang="es" data-theme="">
<head>
  <meta charset="UTF-8">
  <title><%= issue ? 'Editar' : 'Nuevo' %> Issue · <%= project.key %> — QA App</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/app.js" defer></script>
</head>
<body>
<%- include('../partials/_navbar') %>
<button class="theme-toggle" onclick="toggleTheme()" data-testid="btn-theme-toggle" aria-label="Modo oscuro">🌙</button>
<%- include('../partials/_project_nav', { project, memberRole, activeTab: 'issues' }) %>

<div class="page-container" style="max-width:720px">
  <div class="page-header">
    <h2><%= issue ? `Editar ${project.key}-${issue.number}` : 'Nuevo Issue' %></h2>
    <a href="/projects/<%= project.id %>/board" class="btn btn-secondary">Cancelar</a>
  </div>

  <%- include('../partials/_flash') %>

  <% if (errors.length) { %>
    <ul class="error-list" data-testid="error-list">
      <% errors.forEach(e => { %><li><%= e %></li><% }) %>
    </ul>
  <% } %>

  <div class="card">
    <form method="POST" action="<%= issue ? `/projects/${project.id}/issues/${issue.number}/edit` : `/projects/${project.id}/issues` %>" data-testid="issue-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="field">
        <label for="title">Título *</label>
        <input type="text" id="title" name="title" data-testid="input-issue-title"
          value="<%= issue ? issue.title : '' %>" required maxlength="200">
      </div>

      <div class="field">
        <label for="description">Descripción</label>
        <textarea id="description" name="description" data-testid="input-issue-description" rows="5"><%= issue ? issue.description || '' : '' %></textarea>
      </div>

      <div class="form-grid-3">
        <div class="field">
          <label for="type">Tipo</label>
          <select id="type" name="type" data-testid="select-issue-type">
            <option value="task"  <%= (!issue || issue.type==='task')  ? 'selected':'' %>>✅ Task</option>
            <option value="bug"   <%= (issue && issue.type==='bug')    ? 'selected':'' %>>🐛 Bug</option>
            <option value="story" <%= (issue && issue.type==='story')  ? 'selected':'' %>>📖 Story</option>
            <option value="epic"  <%= (issue && issue.type==='epic')   ? 'selected':'' %>>⚡ Epic</option>
          </select>
        </div>

        <div class="field">
          <label for="priority">Prioridad</label>
          <select id="priority" name="priority" data-testid="select-issue-priority">
            <option value="medium"   <%= (!issue || issue.priority==='medium')   ? 'selected':'' %>>🟡 Medium</option>
            <option value="high"     <%= (issue && issue.priority==='high')      ? 'selected':'' %>>🟠 High</option>
            <option value="critical" <%= (issue && issue.priority==='critical')  ? 'selected':'' %>>🔴 Critical</option>
            <option value="low"      <%= (issue && issue.priority==='low')       ? 'selected':'' %>>🔵 Low</option>
          </select>
        </div>

        <div class="field">
          <label for="status">Estado</label>
          <select id="status" name="status" data-testid="select-issue-status">
            <option value="backlog"     <%= (!issue || issue.status==='backlog')     ? 'selected':'' %>>Backlog</option>
            <option value="todo"        <%= (issue && issue.status==='todo')         ? 'selected':'' %>>Por hacer</option>
            <option value="in_progress" <%= (issue && issue.status==='in_progress')  ? 'selected':'' %>>En progreso</option>
            <option value="in_review"   <%= (issue && issue.status==='in_review')    ? 'selected':'' %>>En revisión</option>
            <option value="done"        <%= (issue && issue.status==='done')          ? 'selected':'' %>>Hecho</option>
          </select>
        </div>
      </div>

      <div class="form-grid-2">
        <div class="field">
          <label for="assignee_id">Asignado a</label>
          <select id="assignee_id" name="assignee_id" data-testid="select-assignee">
            <option value="">Sin asignar</option>
            <% members.forEach(m => { %>
              <option value="<%= m.id %>" <%= (issue && issue.assignee_id == m.id) ? 'selected':'' %>><%= m.username %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="sprint_id">Sprint</label>
          <select id="sprint_id" name="sprint_id" data-testid="select-sprint">
            <option value="">Sin sprint (backlog)</option>
            <% sprints.forEach(s => { %>
              <option value="<%= s.id %>" <%= (issue && issue.sprint_id == s.id) ? 'selected':'' %>>
                <%= s.status === 'active' ? '▶ ' : '' %><%= s.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="estimated_hours">Horas estimadas</label>
          <input type="number" id="estimated_hours" name="estimated_hours" data-testid="input-estimated-hours"
            value="<%= issue && issue.estimated_hours ? issue.estimated_hours : '' %>"
            min="0.5" max="999" step="0.5" placeholder="ej: 3.5">
        </div>

        <div class="field">
          <label for="due_date">Fecha límite</label>
          <input type="date" id="due_date" name="due_date" data-testid="input-due-date"
            value="<%= issue && issue.due_date ? issue.due_date : '' %>">
        </div>
      </div>

      <% if (labels.length) { %>
        <div class="field">
          <label>Etiquetas</label>
          <div class="labels-checkboxes" data-testid="labels-checkboxes">
            <% labels.forEach(l => { %>
              <label class="label-checkbox">
                <input type="checkbox" name="labels" value="<%= l.id %>"
                  <%= selectedLabels.includes(l.id) ? 'checked' : '' %>
                  data-testid="checkbox-label-<%= l.id %>">
                <span class="label-pill" style="background:<%= l.color %>; color:<%= isLight(l.color) ? '#000':'#fff' %>"><%= l.name %></span>
              </label>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="form-actions">
        <button type="submit" data-testid="btn-submit-issue"><%= issue ? 'Guardar cambios' : 'Crear issue' %></button>
        <a href="/projects/<%= project.id %>/board">Cancelar</a>
      </div>
    </form>
  </div>
</div>
</body>
</html>
