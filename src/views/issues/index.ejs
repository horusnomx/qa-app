<!DOCTYPE html>
<html lang="es" data-theme="">
<head>
  <meta charset="UTF-8">
  <title>Issues · <%= project.key %> — QA App</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/app.js" defer></script>
</head>
<body>
<%- include('../partials/_navbar') %>
<button class="theme-toggle" onclick="toggleTheme()" data-testid="btn-theme-toggle" aria-label="Modo oscuro">🌙</button>
<%- include('../partials/_project_nav', { project, memberRole, activeTab: 'issues' }) %>

<div class="page-container">
  <%- include('../partials/_flash') %>

  <div class="page-header">
    <h2>Issues</h2>
    <% if (['member','admin','owner'].includes(memberRole)) { %>
      <a href="/projects/<%= project.id %>/issues/new" class="btn" data-testid="btn-new-issue">+ Issue</a>
    <% } %>
  </div>

  <form method="GET" action="/projects/<%= project.id %>/issues" class="filters-bar" data-testid="filters-form">
    <input type="text" name="search" placeholder="Buscar…" value="<%= filters.search %>" data-testid="input-search" class="search-input">
    <select name="type" data-testid="select-filter-type">
      <option value="">Todo tipo</option>
      <option value="epic"  <%= filters.type==='epic'  ? 'selected':'' %>>⚡ Epic</option>
      <option value="story" <%= filters.type==='story' ? 'selected':'' %>>📖 Story</option>
      <option value="task"  <%= filters.type==='task'  ? 'selected':'' %>>✅ Task</option>
      <option value="bug"   <%= filters.type==='bug'   ? 'selected':'' %>>🐛 Bug</option>
    </select>
    <select name="priority" data-testid="select-filter-priority">
      <option value="">Toda prioridad</option>
      <option value="critical" <%= filters.priority==='critical' ? 'selected':'' %>>🔴 Critical</option>
      <option value="high"     <%= filters.priority==='high'     ? 'selected':'' %>>🟠 High</option>
      <option value="medium"   <%= filters.priority==='medium'   ? 'selected':'' %>>🟡 Medium</option>
      <option value="low"      <%= filters.priority==='low'      ? 'selected':'' %>>🔵 Low</option>
    </select>
    <select name="status" data-testid="select-filter-status">
      <option value="">Todo estado</option>
      <option value="backlog"     <%= filters.status==='backlog'     ? 'selected':'' %>>Backlog</option>
      <option value="todo"        <%= filters.status==='todo'        ? 'selected':'' %>>Por hacer</option>
      <option value="in_progress" <%= filters.status==='in_progress' ? 'selected':'' %>>En progreso</option>
      <option value="in_review"   <%= filters.status==='in_review'   ? 'selected':'' %>>En revisión</option>
      <option value="done"        <%= filters.status==='done'        ? 'selected':'' %>>Hecho</option>
    </select>
    <select name="sprint" data-testid="select-filter-sprint">
      <option value="">Todo sprint</option>
      <% sprints.forEach(s => { %>
        <option value="<%= s.id %>" <%= filters.sprint == s.id ? 'selected':'' %>><%= s.name %></option>
      <% }) %>
    </select>
    <select name="limit">
      <% [10,25,50].forEach(n => { %>
        <option value="<%= n %>" <%= pagination.limit===n ? 'selected':'' %>><%= n %> por página</option>
      <% }) %>
    </select>
    <input type="hidden" name="page" value="1">
    <button type="submit" class="btn" data-testid="btn-apply-filters">Filtrar</button>
    <a href="/projects/<%= project.id %>/issues" class="btn btn-secondary" data-testid="btn-clear-filters">Limpiar</a>
  </form>

  <% const TYPE_ICON={ epic:'⚡', story:'📖', task:'✅', bug:'🐛' }; %>
  <% const PRIORITY_ICON={ critical:'🔴', high:'🟠', medium:'🟡', low:'🔵' }; %>
  <% const STATUS_LABEL={ backlog:'Backlog', todo:'Por hacer', in_progress:'En progreso', in_review:'En revisión', done:'Hecho' }; %>

  <% if (!issues.length) { %>
    <p data-testid="empty-message">No hay issues con estos filtros.</p>
  <% } else { %>
    <table class="issues-table" data-testid="issues-table">
      <thead>
        <tr><th>#</th><th></th><th>Título</th><th>Estado</th><th>Prioridad</th><th>Asignado</th><th>Sprint</th><th>Fecha límite</th></tr>
      </thead>
      <tbody>
        <% issues.forEach(issue => { %>
          <tr data-testid="issue-row" data-issue-number="<%= issue.number %>">
            <td><span class="issue-key"><%= project.key %>-<%= issue.number %></span></td>
            <td title="<%= issue.type %>"><%- TYPE_ICON[issue.type] %></td>
            <td><a href="/projects/<%= project.id %>/issues/<%= issue.number %>" data-testid="issue-link"><%= issue.title %></a></td>
            <td><span class="status-badge status-<%= issue.status %>"><%= STATUS_LABEL[issue.status] %></span></td>
            <td><%- PRIORITY_ICON[issue.priority] %> <%= issue.priority %></td>
            <td><%= issue.assignee_name || '—' %></td>
            <td><%= issue.sprint_name  || '—' %></td>
            <td class="<%= issue.due_date && new Date(issue.due_date) < new Date() ? 'overdue' : '' %>"><%= issue.due_date || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="pagination" data-testid="pagination">
      <span class="pagination-info"><%= pagination.total %> issues · Página <%= pagination.page %> de <%= pagination.totalPages %></span>
      <div class="pagination-links">
        <% if (pagination.page > 1) { %>
          <a href="/projects/<%= project.id %>/issues?page=<%= pagination.page-1 %>&limit=<%= pagination.limit %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= filters.type %>&priority=<%= filters.priority %>&status=<%= filters.status %>&sprint=<%= filters.sprint %>"
            class="btn btn-small btn-secondary" data-testid="btn-prev-page">← Anterior</a>
        <% } %>
        <% if (pagination.page < pagination.totalPages) { %>
          <a href="/projects/<%= project.id %>/issues?page=<%= pagination.page+1 %>&limit=<%= pagination.limit %>&search=<%= encodeURIComponent(filters.search) %>&type=<%= filters.type %>&priority=<%= filters.priority %>&status=<%= filters.status %>&sprint=<%= filters.sprint %>"
            class="btn btn-small btn-secondary" data-testid="btn-next-page">Siguiente →</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
</body>
</html>
